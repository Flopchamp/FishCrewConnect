# FishCrewConnect Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001

# Allowed CORS origins (comma-separated — mobile app requests have no origin, so they pass automatically)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:5173,http://localhost:8081

# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=fishcrewconnect
MYSQL_PORT=3306

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_complex

# Email Configuration (Optional)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# M-Pesa Daraja API Configuration
# Set DARAJA_DEMO_MODE=true to use test credentials for demonstration
DARAJA_DEMO_MODE=true
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
DARAJA_BUSINESS_SHORTCODE=your_shortcode
DARAJA_PASSKEY=your_passkey

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIRECTORY=./uploads
